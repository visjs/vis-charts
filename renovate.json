{
  "extends": ["config:best-practices", ":pinOnlyDevDependencies"],
  "dependencyDashboard": false,
  "packageRules": [
    {
      "matchDepTypes": ["peerDependencies"],
      "semanticCommitType": "fix"
    },
    {
      "matchPackageNames": [
        "@egjs/hammerjs",
        "component-emitter",
        "hammerjs",
        "keycharm",
        "moment",
        "propagating-hammerjs",
        "uuid",
        "vis-data",
        "vis-graph3d",
        "vis-network",
        "vis-timeline",
        "vis-util"
      ],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "semanticCommitType": "fix"
    },
    {
      "matchPackageNames": [
        "@egjs/hammerjs",
        "component-emitter",
        "hammerjs",
        "keycharm",
        "moment",
        "propagating-hammerjs",
        "uuid",
        "vis-data",
        "vis-graph3d",
        "vis-network",
        "vis-timeline",
        "vis-util"
      ],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "semanticCommitType": "feat"
    },
    {
      "matchPackageNames": [
        "@egjs/hammerjs",
        "component-emitter",
        "hammerjs",
        "keycharm",
        "moment",
        "propagating-hammerjs",
        "uuid",
        "vis-data",
        "vis-graph3d",
        "vis-network",
        "vis-timeline",
        "vis-util"
      ],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["major"],
      "semanticCommitType": "feat"
    },

    {
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "lockFileMaintenance",
        "pin",
        "digest",
        "pinDigest"
      ],
      "automerge": true
    },
    {
      "matchDepTypes": ["dependencies", "peerDependencies"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
